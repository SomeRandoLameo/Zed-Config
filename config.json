// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "proxy": "",
  "tasks": {
    "enabled": true
  },
  "toolbar": {
    "agent_review": false
  },
  "minimap": {
    "show": "never"
  },
  "relative_line_numbers": "disabled",
  "gutter": {
    "line_numbers": true
  },
  "hover_popover_delay": 100,
  "hover_popover_hiding_delay": 0,
  "terminal": {
    "show_count_badge": true,
    "dock": "bottom"
  },
  "active_pane_modifiers": {},
  "window_decorations": "client",
  "use_system_window_tabs": false,
  "focus_follows_mouse": {
    "enabled": true
  },
  "centered_layout": {
    "right_padding": null,
    "left_padding": null
  },
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enabled": false
  },
  "tabs": {
    "show_close_button": "hover",
    "show_diagnostics": "off",
    "close_position": "left",
    "file_icons": true,
    "git_status": false
  },
  "tab_bar": {
    "show": true
  },
  "title_bar": {
    "button_layout": "platform_default",
    "show_menus": false,
    "show_branch_status_icon": true
  },
  "status_bar": {
    "show_active_file": true,
    "active_encoding_button": "disabled",
    "active_language_button": true
  },
  "project_panel": {
    "hide_root": false,
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "bold_folder_labels": false,
    "indent_size": 20.0,
    "button": true,
    "dock": "left"
  },
  "outline_panel": {
    "button": true,
    "dock": "left"
  },
  "collaboration_panel": {
    "button": true,
    "dock": "left"
  },
  "agent": {
    "button": false,
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "session": {
    "trust_all_worktrees": true
  },
  "base_keymap": "VSCode",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "icon_theme": {
    "mode": "system",
    "light": "JetBrains New UI Icons (Light)",
    "dark": "JetBrains New UI Icons (Dark)"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "JetBrains Islands Light",
    "dark": "JetBrains Islands Dark"
  }
}
